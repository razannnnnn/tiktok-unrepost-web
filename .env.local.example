# TikTok Developer App Credentials
# Dapatkan dari: https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here

# URL aplikasi kamu
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Secret untuk enkripsi session (min 32 karakter, buat sendiri)
SESSION_SECRET=ganti_dengan_random_string_minimal_32_karakter_disini
